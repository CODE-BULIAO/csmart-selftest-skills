{"id":"GEN-001","priority":"P0","requirement":"只允许项目配置中的测试群，生产群和其他业务群必须拒绝","input":"目标群ID","expected":"仅 project-profile.json 中的测试群通过检查，其余返回BLOCKED","evidence":["runtime","sender"],"reason":"防止测试消息进入生产或错误业务群","tags":["safety","routing"],"params":[]}
{"id":"GEN-002","priority":"P0","requirement":"运行时点位字典覆盖 project-profile.json 中定义的所有区域和点位","input":"运行时点位配置","expected":"点位总数和区域分布与 project-profile.json 中 requirements.zones 一致","evidence":["runtime","summary"],"reason":"点位缺失或错序会使全部统计结果失真","tags":["dictionary","summary"],"params":["requirements.zones"]}
{"id":"GEN-003","priority":"P0","requirement":"识别 project-profile.json 中配置的所有触发词","input":"使用每个 trigger_words 中的触发词发送消息","expected":"点位被正确标记为已上报","evidence":["reply","snapshot"],"reason":"验证消息进入解析流程的入口","tags":["trigger","single-point"],"params":["requirements.trigger_words","${FIRST_POINT}"]}
{"id":"GEN-004","priority":"P0","requirement":"正向区间展开","input":"${TRIGGER_WORD} ${FIRST_POINT}-${MID_POINT}","expected":"区间内所有点位被标记","evidence":["reply","snapshot"],"reason":"验证标准连续区间","tags":["range","forward"],"params":["${FIRST_POINT}","${MID_POINT}","${TRIGGER_WORD}"]}
{"id":"GEN-005","priority":"P0","requirement":"反向区间与正向区间结果一致","input":"${TRIGGER_WORD} ${MID_POINT}-${FIRST_POINT}","expected":"区间内所有点位被标记，与正向结果相同","evidence":["reply","snapshot"],"reason":"验证min/max索引算法","tags":["range","reverse"],"params":["${FIRST_POINT}","${MID_POINT}","${TRIGGER_WORD}"]}
{"id":"GEN-006","priority":"P1","requirement":"连接符归一化","input":["${TRIGGER_WORD} ${FIRST_POINT}~${MID_POINT}","${TRIGGER_WORD} ${FIRST_POINT}～${MID_POINT}","${TRIGGER_WORD} ${FIRST_POINT}—${MID_POINT}","${TRIGGER_WORD} ${FIRST_POINT}——${MID_POINT}"],"expected":"所有连接符归一化为 -，区间正确展开","evidence":["reply","snapshot"],"reason":"现场输入连接符不统一","tags":["normalization","separator"],"params":["${FIRST_POINT}","${MID_POINT}","${TRIGGER_WORD}","requirements.separators"]}
{"id":"GEN-007","priority":"P1","requirement":"去除空格并支持中英文逗号","input":["${TRIGGER_WORD} ${FIRST_POINT} - ${MID_POINT}","${TRIGGER_WORD} ${FIRST_POINT},${MID_POINT}","${TRIGGER_WORD} ${FIRST_POINT}，${MID_POINT}"],"expected":"空格不影响区间；逗号分隔的点位分别更新","evidence":["reply","snapshot"],"reason":"覆盖常见输入格式差异","tags":["normalization","list"],"params":["${FIRST_POINT}","${MID_POINT}","${TRIGGER_WORD}"]}
{"id":"GEN-008","priority":"P0","requirement":"支持非数字特殊点位","input":"逐个发送 special_points 中的点位","expected":"每个点位均可独立标记且归属正确区域","evidence":["reply","snapshot","summary"],"reason":"特殊点位不能依赖纯数字楼层解析","tags":["dictionary","special-point"],"params":["${SPECIAL_POINTS}"]}
{"id":"GEN-009","priority":"P1","requirement":"非法端点不污染状态","input":["${TRIGGER_WORD} ${FIRST_POINT}-${INVALID_POINT}","${TRIGGER_WORD} ${INVALID_POINT}","${TRIGGER_WORD}"],"expected":"拒绝或提示格式错误，状态不改变","evidence":["reply","before-after-snapshot"],"reason":"避免错误输入产生虚假已巡记录","tags":["invalid","state-integrity"],"params":["${INVALID_POINT}","${TRIGGER_WORD}","${FIRST_POINT}"]}
{"id":"GEN-010","priority":"P1","requirement":"自然语言输入给出格式引导","input":"与点位格式相似的自然语言","expected":"不误识别点位，并提示正确格式","evidence":["reply","snapshot"],"reason":"覆盖设计文档通常列出的输入风险","tags":["invalid","guidance"],"params":[]}
{"id":"GEN-011","priority":"P0","requirement":"总结正确显示已巡和缺失点","input":"部分点位已上报后触发总结","expected":"已上报点为✅，未上报点为❌，区域和总数正确","evidence":["summary-message","snapshot"],"reason":"总结是用户最终使用的核心输出","tags":["summary","status"],"params":[]}
{"id":"GEN-012","priority":"P0","requirement":"自动总结按配置的 cron 时间执行","input":"summary_schedule 中的 cron 表达式","expected":"每个调度时间均有实际执行证据","evidence":["scheduler-config","scheduler-log","message"],"reason":"配置存在不能证明消息成功推送","tags":["scheduler","summary"],"params":["requirements.summary_schedule"]}
{"id":"GEN-013","priority":"P0","requirement":"支持手动总结","input":"使用 manual_summary_words 中的触发词","expected":"立即生成当前业务日巡火总结","evidence":["reply","summary-message"],"reason":"作为WhatsApp消息漏抓或调度失败时的人工兜底","tags":["manual-summary","reliability"],"params":["requirements.manual_summary_words"]}
{"id":"GEN-014","priority":"P0","requirement":"跨零点切换或重置业务日状态","input":"零点前后分别提交受控点位","expected":"新业务日不包含前一日状态，前一日记录仍可审计","evidence":["before-after-snapshot","summary"],"reason":"防止跨日数据污染","tags":["business-date","reset"],"params":["requirements.business_day_rule"]}
{"id":"GEN-015","priority":"P1","requirement":"每日同一点位按一次统计","input":"同一业务日重复上报同一点位","expected":"该点位在总结中只出现一次，已巡和缺失总数不被重复上报放大","evidence":["reply","before-after-snapshot","summary"],"reason":"原始需求通常规定每日一次，避免重复照片造成统计虚高","tags":["daily-frequency","duplicate","summary"],"params":["${FIRST_POINT}","${TRIGGER_WORD}"]}
